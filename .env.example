# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Job Portal API Configuration
VITE_JOBS_API_KEY=your_job_portal_api_key
VITE_ADZUNA_APP_ID=your_adzuna_app_id
VITE_ADZUNA_APP_KEY=your_adzuna_app_key

# ML Model Configuration
VITE_ML_MODEL_URL=http://localhost:8000
VITE_ML_API_KEY=your_ml_model_api_key

# Instructions:
# 1. Copy this file to .env
# 2. Replace the values with your actual configuration
# 3. Get Firebase values from Firebase Console -> Project Settings -> General -> Web apps
# 4. Get job portal API keys from your job portal provider
# 5. Set up your ML model endpoint URL and API key